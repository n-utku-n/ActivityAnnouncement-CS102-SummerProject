<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project1.MainDashboardController"
            style="-fx-padding: 20;">

    <!-- Üst Menü -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="🎓 BilCall" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
            <Pane HBox.hgrow="ALWAYS"/>
            <Button fx:id="profileButton" text="👤 Profile" />
        </HBox>
    </top>

    <!-- Orta İçerik -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- Kullanıcıya Hoşgeldin Mesajı veya Genel Bilgi -->
            <Label text="Welcome to the Event Platform!" style="-fx-font-size: 18px;" />

            <!-- 📌 Etkinlik Kartlarının Gösterileceği Alan -->
            <Label text="Explore Events" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
            <VBox fx:id="mainEventContainer" spacing="10" style="-fx-border-color: lightgray; -fx-padding: 10;" />

        </VBox>
    </center>

</BorderPane>
